DOUYIN_APP_ENV=production
DOUYIN_SESSION_SECRET=replace-with-at-least-32-random-characters
DOUYIN_INVITE_CODES=replace-with-real-invite-codes
ADMIN_USER=admin
ADMIN_PASS=replace-with-real-admin-password
DOUYIN_HOST=127.0.0.1
DOUYIN_PORT=9000
DOUYIN_DATA_DIR=/var/lib/douyin-downloader
DOUYIN_DOWNLOADS_DIR=/var/lib/douyin-downloader/downloads
DOUYIN_LOGS_DIR=/var/log/douyin-downloader
DOUYIN_TRUST_PROXY_HEADERS=true
DOUYIN_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
DOUYIN_SECURE_COOKIES=true
DOUYIN_PRELOAD_ENABLED=false
PLAYWRIGHT_BROWSERS_PATH=/opt/douyin-downloader-refactor/.playwright
