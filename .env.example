DOUYIN_APP_ENV=development
DOUYIN_INVITE_AUTH_ENABLED=true
DOUYIN_SESSION_SECRET=replace-with-at-least-32-random-characters
DOUYIN_INVITE_CODES=change-me-invite-code
ADMIN_USER=admin
ADMIN_PASS=change-me-admin-password
DOUYIN_HOST=127.0.0.1
DOUYIN_PORT=9000
DOUYIN_CORS_ORIGINS=http://127.0.0.1:9000,http://localhost:9000
DOUYIN_TRUST_PROXY_HEADERS=false
DOUYIN_TRUSTED_PROXY_CIDRS=
DOUYIN_SECURE_COOKIES=false
DOUYIN_METADATA_CACHE_TTL_SECONDS=600
DOUYIN_METADATA_CACHE_MAX_ENTRIES=500
DOUYIN_PRELOAD_ENABLED=true
DOUYIN_PRELOAD_PLATFORMS=douyin
DOUYIN_PRELOAD_MAX_DURATION_SECONDS=180
DOUYIN_PRELOAD_MAX_BYTES=104857600
DOUYIN_PRELOAD_CACHE_MAX_BYTES=536870912
DOUYIN_PRELOAD_CACHE_MAX_ENTRIES=20
DOUYIN_PRELOAD_CONCURRENCY=1
DOUYIN_PRELOAD_WAIT_SECONDS=2.0
DOUYIN_F2_PREWARM_ENABLED=true
DOUYIN_DATA_DIR=var
DOUYIN_DOWNLOADS_DIR=var/downloads
DOUYIN_LOGS_DIR=var/logs
# Used only for TikTok and X/Twitter traffic.
DOUYIN_HTTP_PROXY=
